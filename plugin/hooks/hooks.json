{
  "description": "Protect CLAUDE.md and Claude Code settings from accidental writes",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/pretool_write_guard.py"],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
